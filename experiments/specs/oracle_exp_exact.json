{
  "id": "oracle_exp_exact",
  "description": "Exact recovery control for exp(x) on a small real grid.",
  "target": {
    "kind": "concept",
    "concept": "exp"
  },
  "dataset": {
    "mode": "real_grid",
    "variable": "x",
    "grid": {
      "start": -1.0,
      "stop": 1.0,
      "count": 5
    }
  },
  "search": {
    "mode": "enumerative_real",
    "bounds": {
      "max_depth": 2,
      "max_nodes": 3
    },
    "top_n": 5
  },
  "recovery": {
    "expected_class": "exact_normalized_recovery",
    "expected_canonical_key": "eml(x, 1)"
  }
}
