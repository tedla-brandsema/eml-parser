{
  "id": "oracle_sin_negative",
  "description": "Negative control for sin(x) under current bounded search.",
  "target": {
    "kind": "concept",
    "concept": "sin"
  },
  "dataset": {
    "mode": "real_grid",
    "variable": "x",
    "grid": {
      "start": -1.0,
      "stop": 1.0,
      "count": 5
    }
  },
  "search": {
    "mode": "enumerative_real",
    "bounds": {
      "max_depth": 3,
      "max_nodes": 5
    },
    "top_n": 10
  },
  "recovery": {
    "expected_class": "no_recovery"
  }
}
